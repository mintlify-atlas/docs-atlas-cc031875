  "keyFeatures": [
    "Pluggable RTP/RTCP packet processing framework",
    "Sequential interceptor chaining",
    "NACK generator and responder for packet loss recovery",
    "Google Congestion Control (GCC) for bandwidth estimation",
    "Transport-wide congestion control (TWCC) feedback",
    "Sender and receiver RTCP reports",
    "WebRTC-compliant statistics generation",
    "Jitter buffer for packet reordering",
    "FlexFEC forward error correction",
    "Packet dumping for debugging",
    "RFC 8888 congestion control feedback",
    "Interval PLI generation"
  ],
